rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {uid}
    // Fields: uid, displayName, email, photoURL, language, createdAt
    //
    // Collection: crops
    // Document ID: {cropId}
    // Fields: name, category, season, soil, temperature, irrigation, image, description
    //
    // Collection: market_prices
    // Document ID: {priceId}
    // Fields: crop, state, mandi, price, unit, updatedAt
    //
    // Collection: disease_reports
    // Document ID: {reportId}
    // Fields: userId, cropName, diseaseName, confidence, description, treatment, imageUrl, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jashwanthsappidi509@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.email is string;
    }

    function isValidDiseaseReport(data) {
      return data.keys().hasAll(['userId', 'diseaseName']) &&
             data.userId == request.auth.uid &&
             data.diseaseName is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == uid && isValidUser(request.resource.data);
      allow update: if isOwner(uid) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /crops/{cropId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /market_prices/{priceId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /disease_reports/{reportId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidDiseaseReport(request.resource.data);
      allow update: if false; // Reports should be immutable
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
